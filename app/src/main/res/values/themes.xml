<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Activity hosts a Compose tree, so the platform theme only needs to be a
         no-action-bar shell with a dark window background. -->
    <style name="Theme.Decay" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>
</resources>
